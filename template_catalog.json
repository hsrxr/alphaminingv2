      "source_name": "surprise_zscore_group_rank",
      "description": "group_rank(ts_zscore(divide(actual-forecast, abs(forecast)), d), group)",
      "expression": "group_rank(ts_zscore(divide(subtract(<actual>, <forecast>), abs(<forecast>)), <d>), <group>)",
      "core_slots": ["actual", "forecast"],
      "slots": {
        "actual": {"source": "dataset_field"},
        "forecast": {"source": "dataset_field"},
        "d": {
          "values": [3, 5, 10, 21, 63, 126, 252],
          "representative_values": [21, 126]
        },
        "group": {
          "values": ["market", "sector", "industry"],
          "representative_values": ["industry"]
        }
      },
      "constraints": {
        "not_equal": [["actual", "forecast"]]
      }
    },
