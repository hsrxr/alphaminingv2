{
  "naming": {
    "standard": "TPL_<DOMAIN>_<SIGNAL>_<SHAPE>_V<MAJOR>",
    "regex": "^TPL_[A-Z0-9]+(?:_[A-Z0-9]+){2,}_V[0-9]+$",
    "segments": {
      "TPL": "Template prefix",
      "DOMAIN": "Signal domain such as GROUP, TS, FUND",
      "SIGNAL": "Signal intent keyword",
      "SHAPE": "Expression shape keyword",
      "V<MAJOR>": "Template major version"
    }
  },
  "templates": [
    {
      "template_id": "TPL_GROUP_RATIO_TS2_V1",
      "source_name": "group_ts_ratio",
      "description": "<group_op>(<ts_op>(<field>,<day>) / <ts_op>(<field>,<day2>),<group>)",
      "expression": "<group_op>(divide(<ts_op>(<field>, <day>), <ts_op>(<field>, <day2>)), <group>)",
      "core_slots": ["field"],
      "slots": {
        "group_op": {"slot_kind": "operator", "values": ["group_rank", "group_mean", "group_neutralize"]},
        "ts_op": {"slot_kind": "operator", "values": ["ts_mean", "ts_rank", "ts_zscore"]},
        "field": {"source": "dataset_field"},
        "day": {
          "values": [3, 5, 10, 21],
          "representative_values": [5, 21]
        },
        "day2": {
          "values": [63, 126, 252],
          "representative_values": [126]
        },
        "group": {
          "values": ["market", "sector", "industry"],
          "representative_values": ["industry"]
        }
      }
    },
    {
